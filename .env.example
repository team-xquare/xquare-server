# xquare-server 로컬 개발용 환경변수 예시
# 실제 값은: kubectl get secret xquare-infra-backend-prod -n xquare-dsm-project -o json

PORT=8080

# JWT
JWT_SECRET=<kubectl로 조회>

# GitHub OAuth App (DSM on-prem)
GITHUB_CLIENT_ID=<GitHub App Client ID>
GITHUB_CLIENT_SECRET=<GitHub App Client Secret>

# GitHub App (CI용, 선택사항)
GITHUB_APP_ID=1172114
# GITHUB_APP_PRIVATE_KEY=<privateKey.pem 내용>

# GitOps
GITOPS_TOKEN=<GitHub PAT>
GITOPS_REPO_OWNER=team-xquare
GITOPS_REPO_NAME=xquare-onpremise-project-gitops-repo
GITOPS_BRANCH=main

# Vault (로컬 접근: kubectl port-forward svc/vault -n vault 8200:8200)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=<Vault Token>
VAULT_MOUNT=xquare-kv

# K8s (로컬 kubeconfig 사용, 클러스터 내부 배포 시 불필요)
KUBECONFIG=/path/to/kubeconfig
